# FoundFlow local-dev environment template.
# Copy to `.env` (gitignored) and edit. Used by docker-compose.

# --- Postgres credentials (one DB per service) -------------------------------
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password

FOUND_ITEM_DB_NAME=found_item_db
FOUND_ITEM_DB_USER=found_item_user
FOUND_ITEM_DB_PASSWORD=found_item_password

LOST_ITEM_DB_NAME=lost_item_db
LOST_ITEM_DB_USER=lost_item_user
LOST_ITEM_DB_PASSWORD=lost_item_password

MATCHING_DB_NAME=matching_db
MATCHING_DB_USER=matching_user
MATCHING_DB_PASSWORD=matching_password

NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=notification_password

OPERATIONS_DB_NAME=operations_db
OPERATIONS_DB_USER=operations_user
OPERATIONS_DB_PASSWORD=operations_password

# --- Auth-service dev seed user ----------------------------------------------
DEV_ADMIN_EMAIL=admin@foundflow.local
DEV_ADMIN_PASSWORD=admin12345

# --- Grafana admin credentials (local dev). Override in .env to change. -----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- GenAI service -----------------------------------------------------------
# Provider switch: `local` runs against the bundled Ollama container,
# `openai` requires OPENAI_API_KEY below.
GENAI_PROVIDER=local

# Required when GENAI_PROVIDER=openai. Leave commented out for local dev.
# OPENAI_API_KEY=sk-...

# Model selection — sensible defaults pulled by the ollama-init sidecar.
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Override when GENAI_PROVIDER=openai. Defaults below are cost-efficient.
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Request timeout in seconds (applies to both chat + embed calls).
GENAI_TIMEOUT_SECONDS=30

# --- Photo storage ----------------------------------------------------------
# Local compose uses MinIO, an S3-compatible object store for item photos.
PHOTO_STORAGE_PROVIDER=minio
PHOTO_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
PHOTO_STORAGE_ACCESS_KEY=foundflow
PHOTO_STORAGE_SECRET_KEY=foundflow_dev_secret
