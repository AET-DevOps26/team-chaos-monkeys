# FoundFlow local-dev environment template.
# Copy to `.env` (gitignored) and edit. Used by docker-compose.

# --- Postgres credentials (one DB per service) -------------------------------
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password

FOUND_ITEM_DB_NAME=found_item_db
FOUND_ITEM_DB_USER=found_item_user
FOUND_ITEM_DB_PASSWORD=found_item_password

LOST_ITEM_DB_NAME=lost_item_db
LOST_ITEM_DB_USER=lost_item_user
LOST_ITEM_DB_PASSWORD=lost_item_password

MATCHING_DB_NAME=matching_db
MATCHING_DB_USER=matching_user
MATCHING_DB_PASSWORD=matching_password

NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=notification_password

PICKUP_DB_NAME=pickup_db
PICKUP_DB_USER=pickup_user
PICKUP_DB_PASSWORD=pickup_password

OPERATIONS_DB_NAME=operations_db
OPERATIONS_DB_USER=operations_user
OPERATIONS_DB_PASSWORD=operations_password

# --- Auth-service dev seed user ----------------------------------------------
DEV_ADMIN_EMAIL=admin@foundflow.local
DEV_ADMIN_PASSWORD=admin12345

# --- Demo data seeding -------------------------------------------------------
# When true (default), the operations-service seeds a demo venue and the one-shot
# `seed` container creates a demo staff user plus two found items and a matching
# lost report (with photos, dated across the last few days). Those records go
# through the normal extraction -> embedding -> matching pipeline, so the match
# appears once async processing finishes.
# Set false to start with an empty system.
SEED_DEMO_DATA=true

# --- Grafana admin credentials (local dev). Override in .env to change. -----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- GenAI service -----------------------------------------------------------
# Provider switch:
#   `openai` - default; OPENAI_API_KEY required below (shared via Bitwarden)
#   `local`  - optional Ollama profile; no API key required
#   `fake`   - deterministic canned response; used by CI E2E
GENAI_PROVIDER=openai

# How the Spring lost-item / found-item services reach the GenAI service
# for /extract-attributes. Override only if running outside docker-compose.
# GENAI_BASE_URL=http://genai-service:8000
# GENAI_INTERNAL_TOKEN=
# GENAI_ENABLED=true

# Required for the default OpenAI provider. Retrieve it from the shared
# Bitwarden entry and set it in your gitignored .env file.
# OPENAI_API_KEY=sk-...

# Optional local-provider model selection. Ollama and ollama-init are behind
# the "ollama" Compose profile and are skipped by default. To use them, set
# GENAI_PROVIDER=local and run `docker compose --profile ollama up`.
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Override when GENAI_PROVIDER=openai. Defaults below are cost-efficient.
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Request timeout in seconds (applies to both chat + embed calls).
GENAI_TIMEOUT_SECONDS=30

# Embedding vector dimensionality. Drives matching-service's item_embeddings column
# (via Flyway placeholder), the OpenAI dimensions= parameter, and a startup probe
# in both services. Must match the natural dim of OLLAMA_EMBED_MODEL when GENAI_PROVIDER=local.
EMBEDDING_DIMENSIONS=768

# --- Photo storage ----------------------------------------------------------
# Local compose uses MinIO, an S3-compatible object store for item photos.
PHOTO_STORAGE_PROVIDER=minio
PHOTO_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
PHOTO_STORAGE_ACCESS_KEY=foundflow
PHOTO_STORAGE_SECRET_KEY=foundflow_dev_secret

# --- RabbitMQ domain event broker -------------------------------------------
RABBITMQ_DEFAULT_USER=foundflow
RABBITMQ_DEFAULT_PASS=foundflow_dev_secret

# --- Matching thresholds / embedding contract -------------------------------
EMBEDDING_DIMENSIONS=768
MATCHING_AUTO_INVITE_THRESHOLD=0.85
MATCHING_REPUBLISH_SCORE_DELTA=0.01

# --- Public magic links -----------------------------------------------------
# Browser-facing origin for emailed links (the edge front door, not the gateway):
# the edge serves /report (guest SPA), / (staff SPA), and /api (gateway).
PUBLIC_BASE_URL=http://localhost:3000
MAGIC_LINK_SECRET=foundflow-local-dev-magic-link-secret-change-me
PASSWORD_RESET_TOKEN_MINUTES=30

# Shared service-to-service token for internal-only API calls.
INTERNAL_SERVICE_TOKEN=foundflow-local-dev-internal-token-change-me

# --- Outbound email (notification-service consumer) -------------------------
# notification-service consumes match-invite + pickup-confirmation events from
# RabbitMQ and emails the recipient. By DEFAULT (docker compose up) it delivers
# to the local Mailpit sink (the `mailpit` service) -- captured mail is viewable
# at http://localhost:8025 and NOTHING reaches the shared Brevo account. This
# keeps test/demo flows from hard-bouncing fake recipients and harming Brevo
# sender reputation; leave the block below commented for normal local + CI work.
#
# Set the variables below ONLY for an intentional manual Brevo demo (real send).
# SPRING_MAIL_SMTP_AUTH/STARTTLS default to false so the Mailpit handshake (no
# auth, no TLS) succeeds; Brevo requires both true, so uncomment them too.
# FOUNDFLOW_MAIL_FROM must be a Brevo-verified sender (verify the address in the
# Brevo dashboard first); an unverified From is accepted at SMTP but then blocked.
# It also accepts an RFC 5322 display-name form -- "Name <addr>" -- to brand the
# sender without extra verification, e.g. FoundFlow <foundflow.app@gmail.com>.
# SPRING_MAIL_HOST=smtp-relay.brevo.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true
# SPRING_MAIL_USERNAME=
# SPRING_MAIL_PASSWORD=
# FOUNDFLOW_MAIL_FROM=FoundFlow <foundflow.app@gmail.com>
