# Rendered by Ansible. Do not edit on the VM — re-run the playbook.

# --- Postgres credentials (one DB per service) -------------------------------
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password

FOUND_ITEM_DB_NAME=found_item_db
FOUND_ITEM_DB_USER=found_item_user
FOUND_ITEM_DB_PASSWORD=found_item_password

LOST_ITEM_DB_NAME=lost_item_db
LOST_ITEM_DB_USER=lost_item_user
LOST_ITEM_DB_PASSWORD=lost_item_password

MATCHING_DB_NAME=matching_db
MATCHING_DB_USER=matching_user
MATCHING_DB_PASSWORD=matching_password

NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=notification_password

PICKUP_DB_NAME=pickup_db
PICKUP_DB_USER=pickup_user
PICKUP_DB_PASSWORD=pickup_password

OPERATIONS_DB_NAME=operations_db
OPERATIONS_DB_USER=operations_user
OPERATIONS_DB_PASSWORD=operations_password

# --- Auth-service dev seed user ----------------------------------------------
DEV_ADMIN_EMAIL=admin@foundflow.local
DEV_ADMIN_PASSWORD=admin12345

# --- Grafana admin credentials -----------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- RabbitMQ (intake → matching → notification event bus) -------------------
# docker-compose.yml uses ${RABBITMQ_DEFAULT_USER:?...} / ${RABBITMQ_DEFAULT_PASS:?...};
# without these values, compose-up fails before any service starts.
RABBITMQ_DEFAULT_USER=foundflow
RABBITMQ_DEFAULT_PASS=foundflow

# --- Internal service-to-service calls --------------------------------------
INTERNAL_SERVICE_TOKEN={{ internal_service_token }}
# --- Magic-link signing -------------------------------------------------------
MAGIC_LINK_SECRET=foundflow-azure-magic-link-secret-change-me

# --- Public URLs --------------------------------------------------------------
PUBLIC_BASE_URL={{ public_base_url }}

# --- MinIO (photo storage for lost-item and found-item services) -------------
# PHOTO_STORAGE_PUBLIC_ENDPOINT points the browser at MinIO for direct photo
# fetches. localhost works for cluster-internal calls; browser-side rendering
# from outside the VM is deferred (see Helm chart commit 4884315).
PHOTO_STORAGE_PROVIDER=minio
PHOTO_STORAGE_ACCESS_KEY=foundflow
PHOTO_STORAGE_SECRET_KEY=foundflow
PHOTO_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000

# --- GenAI service (forced to OpenAI on the VM; Ollama is excluded) ----------
GENAI_PROVIDER=openai
OPENAI_API_KEY={{ openai_api_key }}
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
GENAI_TIMEOUT_SECONDS=30

# --- Outbound email (Brevo SMTP on the Azure VM) -----------------------------
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS=true
SPRING_MAIL_USERNAME={{ brevo_smtp_username }}
SPRING_MAIL_PASSWORD={{ brevo_smtp_password }}
FOUNDFLOW_MAIL_FROM={{ brevo_mail_from }}

# --- Image registry / tag ----------------------------------------------------
IMAGE_REGISTRY={{ image_registry }}
IMAGE_TAG={{ image_tag }}
