# GenAI service env template (service-local, for non-compose dev).
# Copy to .env (gitignored). When running via docker-compose, use the
# repo-root .env.example instead — compose reads that.

GENAI_PROVIDER=local

# Required when GENAI_PROVIDER=openai.
# OPENAI_API_KEY=sk-...

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Use http://host.docker.internal:11434 if running this service on host
# while Ollama is in compose, or http://localhost:11434 for fully-host dev.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

GENAI_TIMEOUT_SECONDS=30
