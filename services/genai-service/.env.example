# GenAI service env template (service-local, for non-compose dev).
# Copy to .env (gitignored). When running via docker-compose, use the
# repo-root .env.example instead — compose reads that.

GENAI_PROVIDER=openai

# Required for the default OpenAI provider. Retrieve the development key from
# the shared Bitwarden entry.
# OPENAI_API_KEY=sk-...

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Optional local-provider configuration. Set GENAI_PROVIDER=local, then use
# http://host.docker.internal:11434 if Ollama is in Compose or
# http://localhost:11434 for fully-host development.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
# Vision-capable model used when `/extract-attributes` is called with an
# image. Local-vision latency on CPU is high (~15-30 s for llava:7b);
# the demo path is `GENAI_PROVIDER=openai`. See ADR 0001 §7.
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

GENAI_TIMEOUT_SECONDS=30
